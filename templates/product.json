    "custom_liquid_NjK73z": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% comment %} Jaysou's how to use {% endcomment %}\n<style>\n  .js-howto {\n    background: #fa007b;\n    padding: 110px 24px;\n  }\n  .js-howto-heading {\n    font-family: 'Cormorant Garamond', serif;\n    font-weight: 500;\n    font-size: 48px;\n    line-height: 1.05;\n    color: #FFFFFF;\n    text-align: center;\n    margin: 0 auto 14px;\n    letter-spacing: -0.01em;\n  }\n  .js-howto-sub {\n    text-align: center;\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    color: rgba(31, 27, 23, 0.6);\n    margin: 0 auto 64px;\n    max-width: 520px;\n    line-height: 1.6;\n  }\n  .js-howto-grid {\n    max-width: 1100px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 32px;\n  }\n  .js-howto-step {\n    text-align: left;\n  }\n  .js-howto-number {\n    font-family: 'Cormorant Garamond', serif;\n    font-weight: 500;\n    font-size: 56px;\n    line-height: 1;\n    color: #FFFFF;\n    margin: 0 0 20px;\n    letter-spacing: -0.02em;\n  }\n  .js-howto-step-title {\n    font-family: 'Inter', sans-serif;\n    font-weight: 600;\n    font-size: 14px;\n    color: #FFFFFF;\n    margin: 0 0 10px;\n    letter-spacing: 0.04em;\n    text-transform: uppercase;\n  }\n  .js-howto-step-body {\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #FFFFFF;\n    margin: 0;\n  }\n  @media (max-width: 749px) {\n    .js-howto { padding: 56px 16px; }\n    .js-howto-heading { font-size: 32px; }\n    .js-howto-grid { grid-template-columns: 1fr 1fr; gap: 32px 20px; }\n    .js-howto-number { font-size: 44px; margin-bottom: 14px; }\n  }\n</style>\n\n<div class=\"js-howto\">\n  <h2 class=\"js-howto-heading\">The treatment.</h2>\n  <p class=\"js-howto-sub\">Three minutes. Once or twice a week.</p>\n  \n  <div class=\"js-howto-grid\">\n    <div class=\"js-howto-step\">\n      <p class=\"js-howto-number\">01</p>\n      <p class=\"js-howto-step-title\">Cleanse and dry</p>\n      <p class=\"js-howto-step-body\">Wash your face thoroughly. Pat dry — skin should be clean and dry to the touch before applying.</p>\n    </div>\n    \n    <div class=\"js-howto-step\">\n      <p class=\"js-howto-number\">02</p>\n      <p class=\"js-howto-step-title\">Apply a thin layer</p>\n      <p class=\"js-howto-step-body\">Use clean fingers or a spatula. Apply evenly to the T-zone — nose, forehead, chin. Avoid the eye area.</p>\n    </div>\n    \n    <div class=\"js-howto-step\">\n      <p class=\"js-howto-number\">03</p>\n      <p class=\"js-howto-step-title\">Wait 3–5 minutes</p>\n      <p class=\"js-howto-step-body\">The mask will dry and feel cool. Don't leave on more than 5 minutes — the actives work fast.</p>\n    </div>\n    \n    <div class=\"js-howto-step\">\n      <p class=\"js-howto-number\">04</p>\n      <p class=\"js-howto-step-title\">Rinse with warm water</p>\n      <p class=\"js-howto-step-body\">Massage gently in circular motions. Pat dry. Follow with your usual moisturizer.</p>\n    </div>\n  </div>\n</div>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
