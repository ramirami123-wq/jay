      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% comment %} Jaysou's comparison table - mask vs strips {% endcomment %}\n<style>\n  .js-cmp {\n    background: #FFFFFF;\n    padding: 110px 24px;\n  }\n  .js-cmp-heading {\n    font-family: 'Cormorant Garamond', serif;\n    font-weight: 500;\n    font-size: 48px;\n    line-height: 1.05;\n    color: #1F1B17;\n    text-align: center;\n    margin: 0 auto 14px;\n    letter-spacing: -0.01em;\n  }\n  .js-cmp-sub {\n    text-align: center;\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    color: rgba(31, 27, 23, 0.6);\n    margin: 0 auto 56px;\n    max-width: 520px;\n    line-height: 1.6;\n  }\n  .js-cmp-table {\n    max-width: 880px;\n    margin: 0 auto;\n    background: #fa007b;\n    border-radius: 4px;\n    overflow: hidden;\n    border: 1px solid rgba(31, 27, 23, 0.08);\n  }\n  .js-cmp-row {\n    display: grid;\n    grid-template-columns: 1.6fr 1fr 1fr;\n    border-bottom: 1px solid rgba(31, 27, 23, 0.08);\n  }\n  .js-cmp-row:last-child { border-bottom: none; }\n  .js-cmp-header {\n    background: #1F1B17;\n    color: #F2EBE0;\n  }\n  .js-cmp-header .js-cmp-us,\n  .js-cmp-header .js-cmp-them {\n    font-family: 'Inter', sans-serif;\n    font-weight: 600;\n    font-size: 12px;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n  .js-cmp-header .js-cmp-us { color: #FFFFFF; }\n  .js-cmp-header .js-cmp-them { color: rgba(242, 235, 224, 0.55); }\n  .js-cmp-cell {\n    padding: 22px 24px;\n    display: flex;\n    align-items: center;\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    color: #FFFFFF;\n    line-height: 1.4;\n  }\n  .js-cmp-feature { font-weight: 500; }\n  .js-cmp-us, .js-cmp-them { justify-content: center; }\n  .js-cmp-check, .js-cmp-x {\n    width: 22px;\n    height: 22px;\n    flex-shrink: 0;\n  }\n  .js-cmp-check { color: #1F1B17; }\n  .js-cmp-x { color: rgba(31, 27, 23, 0.25); }\n  @media (max-width: 749px) {\n    .js-cmp { padding: 56px 16px; }\n    .js-cmp-heading { font-size: 32px; }\n    .js-cmp-row { grid-template-columns: 1.4fr 0.7fr 0.7fr; }\n    .js-cmp-cell { padding: 16px 12px; font-size: 13px; }\n    .js-cmp-feature { font-size: 13px; }\n    .js-cmp-header .js-cmp-us,\n    .js-cmp-header .js-cmp-them { font-size: 10px; }\n    .js-cmp-check, .js-cmp-x { width: 18px; height: 18px; }\n  }\n</style>\n\n<div class=\"js-cmp\">\n  <h2 class=\"js-cmp-heading\">A treatment mask vs nose strips.</h2>\n  <p class=\"js-cmp-sub\">Six reasons this works where strips fail.</p>\n  \n  <div class=\"js-cmp-table\">\n    <div class=\"js-cmp-row js-cmp-header\">\n      <div class=\"js-cmp-cell\"></div>\n      <div class=\"js-cmp-cell js-cmp-us\">Mud Mask</div>\n      <div class=\"js-cmp-cell js-cmp-them\">Nose Strips</div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Triple-acid complex (AHA, BHA, PHA)</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Five-clay mineral blend</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Cools and calms on contact</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Visibly tightens pores in 3–5 min</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Gentle on sensitive skin</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n    \n    <div class=\"js-cmp-row\">\n      <div class=\"js-cmp-cell js-cmp-feature\">Works on full T-zone, not just nose</div>\n      <div class=\"js-cmp-cell js-cmp-us\"><svg class=\"js-cmp-check\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></div>\n      <div class=\"js-cmp-cell js-cmp-them\"><svg class=\"js-cmp-x\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></div>\n    </div>\n  </div>\n</div>",
