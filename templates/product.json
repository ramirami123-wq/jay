        "custom_liquid_TJV3Ri": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% comment %} Jaysou's promo band - sale + countdown + reviews {% endcomment %}\n<style>\n  .js-promo {\n    background: #F2EBE0;\n    border: 1px solid rgba(139, 111, 78, 0.25);\n    border-radius: 4px;\n    padding: 18px;\n    margin: 16px 0;\n  }\n  .js-promo-inner {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    flex-wrap: wrap;\n  }\n  .js-promo-sale {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .js-promo-badge {\n    background: #8B6F4E;\n    color: #F2EBE0;\n    font-family: 'Inter', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 5px 10px;\n    border-radius: 2px;\n  }\n  .js-promo-text {\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 500;\n    color: #1F1B17;\n  }\n  .js-promo-timer {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    color: #1F1B17;\n  }\n  .js-promo-timer-label {\n    font-weight: 500;\n    margin-right: 6px;\n    color: rgba(31, 27, 23, 0.7);\n    letter-spacing: 0.02em;\n  }\n  .js-promo-timer-value {\n    background: #1F1B17;\n    color: #F2EBE0;\n    font-variant-numeric: tabular-nums;\n    padding: 4px 8px;\n    border-radius: 2px;\n    font-weight: 600;\n    font-size: 12px;\n    letter-spacing: 0.02em;\n    min-width: 26px;\n    text-align: center;\n    display: inline-block;\n  }\n  .js-promo-reviews {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .js-promo-stars {\n    color: #8B6F4E;\n    letter-spacing: 1px;\n    font-size: 14px;\n  }\n  .js-promo-rating {\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    color: #1F1B17;\n    font-weight: 600;\n  }\n  .js-promo-rating-meta {\n    color: rgba(31, 27, 23, 0.6);\n    font-size: 12px;\n    font-family: 'Inter', sans-serif;\n  }\n  @media (max-width: 749px) {\n    .js-promo { padding: 14px; margin: 12px 0; }\n    .js-promo-inner { gap: 10px; justify-content: center; }\n    .js-promo-text { display: none; }\n    .js-promo-timer-label { font-size: 12px; }\n  }\n</style>\n\n<div class=\"js-promo\">\n  <div class=\"js-promo-inner\">\n    <div class=\"js-promo-sale\">\n      <span class=\"js-promo-badge\">50% OFF</span>\n      <span class=\"js-promo-text\">Launch promotion</span>\n    </div>\n    <div class=\"js-promo-timer\">\n      <span class=\"js-promo-timer-label\">Ends in</span>\n      <span class=\"js-promo-timer-value\" id=\"js-promo-h\">12</span>\n      <span>:</span>\n      <span class=\"js-promo-timer-value\" id=\"js-promo-m\">00</span>\n      <span>:</span>\n      <span class=\"js-promo-timer-value\" id=\"js-promo-s\">00</span>\n    </div>\n    <div class=\"js-promo-reviews\">\n      <span class=\"js-promo-stars\">★★★★★</span>\n      <span class=\"js-promo-rating\">4.9</span>\n      <span class=\"js-promo-rating-meta\">(194 reviews)</span>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  function pad(n) { return n.toString().padStart(2, '0'); }\n  function tick() {\n    var stored = sessionStorage.getItem('js_promo_end');\n    var end;\n    if (stored) {\n      end = parseInt(stored, 10);\n      if (isNaN(end) || end < Date.now()) {\n        end = Date.now() + 12 * 60 * 60 * 1000;\n        sessionStorage.setItem('js_promo_end', String(end));\n      }\n    } else {\n      end = Date.now() + 12 * 60 * 60 * 1000;\n      sessionStorage.setItem('js_promo_end', String(end));\n    }\n    var diff = Math.max(0, end - Date.now());\n    var h = Math.floor(diff / (1000 * 60 * 60));\n    var m = Math.floor((diff / (1000 * 60)) % 60);\n    var s = Math.floor((diff / 1000) % 60);\n    var hEl = document.getElementById('js-promo-h');\n    var mEl = document.getElementById('js-promo-m');\n    var sEl = document.getElementById('js-promo-s');\n    if (hEl) hEl.textContent = pad(h);\n    if (mEl) mEl.textContent = pad(m);\n    if (sEl) sEl.textContent = pad(s);\n  }\n  tick();\n  setInterval(tick, 1000);\n})();\n</script>"
          }
